// Mục đích: Mô tả enum, mô hình, quan hệ và chỉ mục của dữ liệu PostgreSQL.
// Mỗi mô hình bên dưới tương ứng với một miền nghiệp vụ của hệ thống đặt vé.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Định nghĩa các giá trị hợp lệ của Role để tránh trạng thái tự do trong cơ sở dữ liệu.
enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

// Định nghĩa các giá trị hợp lệ của MovieStatus để tránh trạng thái tự do trong cơ sở dữ liệu.
enum MovieStatus {
  DRAFT
  NOW_SHOWING
  COMING_SOON
  ENDED
}

// Định nghĩa các giá trị hợp lệ của SeatType để tránh trạng thái tự do trong cơ sở dữ liệu.
enum SeatType {
  STANDARD
  VIP
  COUPLE
}

// Định nghĩa các giá trị hợp lệ của ShowtimeSeatStatus để tránh trạng thái tự do trong cơ sở dữ liệu.
enum ShowtimeSeatStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
}

// Định nghĩa các giá trị hợp lệ của BookingStatus để tránh trạng thái tự do trong cơ sở dữ liệu.
enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
}

// Định nghĩa các giá trị hợp lệ của PaymentStatus để tránh trạng thái tự do trong cơ sở dữ liệu.
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

// Định nghĩa các giá trị hợp lệ của TicketStatus để tránh trạng thái tự do trong cơ sở dữ liệu.
enum TicketStatus {
  VALID
  USED
  CANCELLED
  EXPIRED
}

// Mô hình người dùng và vai trò truy cập.
model User {
  id            String         @id @default(cuid())
  username      String?        @unique
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          Role           @default(CUSTOMER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  refreshTokens RefreshToken[]
  movieReviews  MovieReview[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// Mô hình refresh token phục vụ phiên đăng nhập.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Mô hình phim và thông tin trình chiếu.
model Movie {
  id          String        @id @default(cuid())
  tmdbId      Int?
  title       String
  description String?       @db.Text
  posterUrl   String?
  trailerUrl  String?
  durationMin Int
  releaseDate DateTime?
  ageRating   String        @default("P")
  status      MovieStatus   @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  genres      MovieGenre[]
  showtimes   Showtime[]
  reviews     MovieReview[]

  @@index([status])
  @@index([releaseDate])
  @@index([title])
  @@index([tmdbId])
  @@map("movies")
}

// Mô hình đánh giá phim của khách đã mua vé.
model MovieReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
  @@index([movieId])
  @@index([userId])
  @@map("movie_reviews")
}

// Mô hình thể loại phim.
model Genre {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  movies    MovieGenre[]

  @@map("genres")
}

// Mô hình quan hệ nhiều-nhiều giữa phim và thể loại.
model MovieGenre {
  movieId String
  genreId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@index([genreId])
  @@map("movie_genres")
}

// Mô hình chuỗi thương hiệu rạp.
model CinemaChain {
  id        String   @id @default(cuid())
  name      String
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cinemas   Cinema[]

  @@unique([name, city])
  @@index([city])
  @@index([name])
  @@map("cinema_chains")
}

// Mô hình chi nhánh rạp tại Đà Nẵng.
model Cinema {
  id           String              @id @default(cuid())
  chainId      String?
  chain        CinemaChain?        @relation(fields: [chainId], references: [id], onDelete: SetNull)
  code         String?             @unique
  name         String
  address      String?
  ward         String?
  city         String?
  phone        String?
  email        String?
  imageUrl     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  rooms        Room[]
  ticketPrices CinemaTicketPrice[]

  @@index([chainId])
  @@index([code])
  @@index([ward])
  @@index([city])
  @@index([name])
  @@map("cinemas")
}

// Mô hình bảng giá ghế riêng của từng rạp.
model CinemaTicketPrice {
  id        String   @id @default(cuid())
  cinemaId  String
  cinema    Cinema   @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  seatType  SeatType
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cinemaId, seatType])
  @@index([cinemaId, isActive])
  @@index([seatType])
  @@map("cinema_ticket_prices")
}

// Mô hình phòng chiếu thuộc một rạp.
model Room {
  id        String     @id @default(cuid())
  cinemaId  String
  cinema    Cinema     @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  seats     Seat[]
  showtimes Showtime[]

  @@unique([cinemaId, name])
  @@index([cinemaId])
  @@map("rooms")
}

// Mô hình ghế vật lý và vị trí trong phòng.
model Seat {
  id            String         @id @default(cuid())
  roomId        String
  room          Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  row           String
  number        Int
  position      Int
  type          SeatType       @default(STANDARD)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  showtimeSeats ShowtimeSeat[]

  @@unique([roomId, row, number])
  @@unique([roomId, row, position])
  @@index([roomId])
  @@index([type])
  @@map("seats")
}

// Mô hình suất chiếu của phim trong một phòng.
model Showtime {
  id            String         @id @default(cuid())
  movieId       String
  movie         Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  roomId        String
  room          Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  startAt       DateTime
  endAt         DateTime
  basePrice     Decimal        @db.Decimal(10, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  showtimeSeats ShowtimeSeat[]
  bookings      Booking[]

  @@index([movieId, startAt])
  @@index([roomId, startAt])
  @@index([startAt])
  @@map("showtimes")
}

// Mô hình trạng thái bền vững và giá ghế theo suất chiếu.
model ShowtimeSeat {
  id           String             @id @default(cuid())
  showtimeId   String
  showtime     Showtime           @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  seatId       String
  seat         Seat               @relation(fields: [seatId], references: [id], onDelete: Cascade)
  status       ShowtimeSeatStatus @default(AVAILABLE)
  price        Decimal            @db.Decimal(10, 2)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  bookingItems BookingItem[]

  @@unique([showtimeId, seatId])
  @@index([showtimeId, status])
  @@index([seatId, status])
  @@index([status])
  @@map("showtime_seats")
}

// Mô hình đơn đặt vé của người dùng.
model Booking {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtimeId   String
  showtime     Showtime           @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  status       BookingStatus      @default(PENDING)
  totalAmount  Decimal            @db.Decimal(10, 2)
  currency     String             @default("VND")
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  bookingItems BookingItem[]
  comboItems   BookingComboItem[]
  payments     Payment[]
  tickets      Ticket[]

  @@index([userId, createdAt])
  @@index([showtimeId, status])
  @@index([status, createdAt])
  @@map("bookings")
}

// Mô hình combo bắp nước có thể bán.
model ConcessionCombo {
  id           String             @id @default(cuid())
  name         String
  description  String?            @db.Text
  price        Decimal            @db.Decimal(10, 2)
  imageUrl     String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  bookingItems BookingComboItem[]

  @@index([isActive])
  @@index([name])
  @@map("concession_combos")
}

// Mô hình combo đã chọn trong một booking.
model BookingComboItem {
  id        String          @id @default(cuid())
  bookingId String
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  comboId   String
  combo     ConcessionCombo @relation(fields: [comboId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([bookingId, comboId])
  @@index([bookingId])
  @@index([comboId])
  @@map("booking_combo_items")
}

// Mô hình ghế đã chọn trong một booking.
model BookingItem {
  id             String       @id @default(cuid())
  bookingId      String
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  showtimeSeatId String
  showtimeSeat   ShowtimeSeat @relation(fields: [showtimeSeatId], references: [id], onDelete: Cascade)
  unitPrice      Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tickets        Ticket[]

  @@unique([bookingId, showtimeSeatId])
  @@index([bookingId])
  @@index([showtimeSeatId])
  @@map("booking_items")
}

// Mô hình giao dịch thanh toán của booking.
model Payment {
  id                    String        @id @default(cuid())
  bookingId             String
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider              String?
  providerRef           String?
  providerTransactionId String?       @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("VND")
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([bookingId, status])
  @@index([status, createdAt])
  @@map("payments")
}

// Mô hình vé điện tử phát hành cho từng ghế.
model Ticket {
  id            String         @id @default(cuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingItemId String
  bookingItem   BookingItem    @relation(fields: [bookingItemId], references: [id], onDelete: Cascade)
  qrToken       String         @unique
  status        TicketStatus   @default(VALID)
  issuedAt      DateTime       @default(now())
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  checkIn       TicketCheckIn?

  @@index([bookingId])
  @@index([bookingItemId])
  @@index([status, expiresAt])
  @@map("tickets")
}

// Mô hình lịch sử nhân viên quét và soát vé.
model TicketCheckIn {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  checkedInAt DateTime @default(now())
  checkedInBy String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([checkedInAt])
  @@map("ticket_check_ins")
}
